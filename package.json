{
  "name": "medyield",
  "version": "0.1.0",
  "private": true,
  "description": "MedYield monorepo — Foundry contracts + Next.js frontend.",
  "license": "MIT",
  "scripts": {
    "build": "pnpm --filter @medyield/foundry build && pnpm --filter @medyield/nextjs build",
    "dev": "pnpm --filter @medyield/nextjs dev",
    "test": "pnpm --filter @medyield/foundry test",
    "forge:build": "pnpm --filter @medyield/foundry build",
    "wagmi:generate": "pnpm --filter @medyield/nextjs wagmi:generate",
    "clean": "pnpm -r run clean && rm -rf node_modules"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  }
}
